# ─── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL — Neon (recommandé) ou Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/naya?sslmode=require

# ─── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
SESSION_SECRET=change-me-32-chars-minimum-random

# Générer avec : openssl rand -base64 64
JWT_SECRET=change-me-64-chars-minimum-random-for-mobile-jwt

# ─── Serveur ──────────────────────────────────────────────────────────────────
NODE_ENV=development
# PORT par défaut : 3000 en local (Railway injecte sa propre valeur en prod)
PORT=3000

# ─── App Mobile Expo ──────────────────────────────────────────────────────────
# En développement local : IP LAN de ton Mac (pas localhost)
# Exemple : EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
# En production Railway : EXPO_PUBLIC_API_URL=https://ton-app.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Optionnel — Google Cloud Storage (médias campagnes) ──────────────────────
# GCS_BUCKET_NAME=naya-media
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
